<%- include('../layout/menu-atas') %>
<%- include('../layout/menu-kiri') %>

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Master User</h1>

        <a href="/user/create" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Tambah User
        </a>
    </div>

    <hr>

    <table id="table_user" class="table table-bordered table-striped w-100">
        <thead class="table-dark">
            <tr>
                <th width="50">No</th>
                <th>Username</th>
                <th>Nama Lengkap</th>
                <th>Role</th>
                <th>Status</th>
                <th width="150">Aksi</th>
            </tr>
        </thead>

    <tbody>
    
        <% if (data_user && data_user.length> 0) { %>
    
            <% data_user.forEach(function(user, index){ %>
    
                <tr>
                    <td>
                        <%= index + 1 %>
                    </td>
                    <td>
                        <%= user.username || '-' %>
                    </td>
                    <td>
                        <%= user.nama || '-' %>
                    </td>
                    <td>
                        <%= user.role || '-' %>
                    </td>
    
                    <td>
                        <% if(user.status==='aktif' ){ %>
                            <span class="badge bg-success">Aktif</span>
                            <% } else { %>
                                <span class="badge bg-danger">Nonaktif</span>
                                <% } %>
                    </td>
    
                    <td>
    
                        <a href="/user/edit/<%= user.id %>" class="btn btn-warning btn-sm">
                            Edit
                        </a>
    
                        <a href="/user/delete/<%= user.id %>" class="btn btn-danger btn-sm"
                            onclick="return confirm('Yakin hapus user ini?')">
                            Hapus
                        </a>
    
                    </td>
                </tr>
    
                <% }) %>
    
                    <% } %>
    
    </tbody>
    </table>

</div>


<!-- DATATABLES -->
<script src="/datatables-2.3.7/js/dataTables.js"></script>
<script src="/datatables-2.3.7/js/dataTables.bootstrap5.js"></script>

<script>

document.addEventListener("DOMContentLoaded", function(){

    const table = document.querySelector('#table_user');

    if(table){
        new DataTable(table,{
            pageLength:10,
            lengthMenu:[10,25,50,100],
            responsive:true
        });
    }

});

</script>

<%- include('../layout/footer') %>